# Maintainer: Tales A. Mendonça <talesam@gmail.com>

pkgname=cinnamon-big-shot
pkgdesc="Enhanced Screenshot & Screencast for Cinnamon — annotation tools, audio recording, FPS/resolution control"
depends=('cinnamon>=5.4' 'gstreamer' 'gst-plugins-base' 'gst-plugins-good' 'gst-plugins-bad' 'gst-plugin-va' 'pciutils')
optdepends=(
    'gst-plugins-ugly: additional GStreamer codecs (x264, mpeg2, a52)'
)
makedepends=('gettext')
pkgver=$(date +%y.%m.%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('MIT')
url="https://github.com/big-comm/${pkgname}"
source=("git+${url}.git")
md5sums=('SKIP')

if [ -e "${pkgname}.install" ]; then
    install=${pkgname}.install
elif [ -e "pkgbuild.install" ]; then
    install=pkgbuild.install
fi

prepare() {
    cd "${srcdir}/${pkgname}"
}

build() {
    cd "${srcdir}/${pkgname}"
    local _uuid="big-shot@bigcommunity.org"
    local _extdir="usr/share/cinnamon/extensions/${_uuid}"
    local _podir="${_extdir}/po"
    local _localedir="${_extdir}/locale"

    for po_file in "${_podir}"/*.po; do
        [ -f "$po_file" ] || continue
        local lang=$(basename "$po_file" .po)
        local mo_dir="${_localedir}/${lang}/LC_MESSAGES"
        mkdir -p "$mo_dir"
        msgfmt "$po_file" -o "${mo_dir}/${_uuid}.mo"
    done
}

check() {
    cd "${srcdir}/${pkgname}"
}

package() {
    cd "${srcdir}/${pkgname}"

    if [ -d "${pkgname}" ]; then
        srcdir="${srcdir}/${pkgname}/${pkgname}"
    else
        srcdir="${srcdir}/${pkgname}"
    fi

    local dirs=("usr" "etc" "opt")
    for dir in "${dirs[@]}"; do
        if [ -d "${srcdir}/${dir}" ]; then
            cp -a "${srcdir}/${dir}" "${pkgdir}/"
        fi
    done

    if [ -f "LICENSE" ]; then
        install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    fi

    if [ -f "README.md" ]; then
        install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    fi
}
